# Manann — variables de entorno (plantilla)
# Copia este fichero a .env.local y rellena los valores reales.
# NUNCA commitees .env / .env.local con valores reales.

# ── Base de datos (Neon Postgres, cadena pooled) ──────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Cadena de producción (swap manual en el workflow prod-only; el código lee DATABASE_URL)
DATABASE_URL_PROD="postgresql://user:password@host-prod/db?sslmode=require"

# ── Better Auth (magic-link) ──────────────────────────────────────────────────
# Genera un secreto nuevo: openssl rand -base64 32
BETTER_AUTH_SECRET="genera-un-secreto-de-32-bytes"
# En local fija la URL; en Vercel se infiere del request si falta
BETTER_AUTH_URL="http://localhost:3000"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Manann <no-reply@tu-dominio.com>"

# ── IA documental (Gemini vía Vercel AI SDK — leída implícitamente) ────────────
GOOGLE_GENERATIVE_AI_API_KEY="tu-clave-de-google-ai-studio"

# ── Almacenamiento (Vercel Blob — leída implícitamente por @vercel/blob) ───────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ── Tracking (ShipsGo) ────────────────────────────────────────────────────────
SHIPSGO_API_KEY=""
SHIPSGO_ENABLED="false"

# ── Cron (alertas de ETA) ─────────────────────────────────────────────────────
# Token Bearer que protege /api/cron/eta-alerts
CRON_SECRET="genera-un-token-aleatorio"

# ── URL pública (para enlaces en emails de invitación) ────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
